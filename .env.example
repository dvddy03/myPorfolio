# MongoDB local
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secret123
MONGO_DB_NAME=myportfolio

# Backend
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://admin:secret123@mongo:27017/myportfolio?authSource=admin

# Pour déploiement Atlas (décommenter)
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/myportfolio?retryWrites=true&w=majority
